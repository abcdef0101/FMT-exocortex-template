# Скопируй этот файл: cp secrets.example ~/.iwe-test-vm/secrets/.env
# chmod 600 !!!

# OpenCode / DeepSeek V4 Pro
OPENAI_API_KEY=sk-your-deepseek-key-here
OPENAI_BASE_URL=https://api.deepseek.com/v1

# GLM 5.1 Coding (если используется)
GLM_API_KEY=your-glm-key-here

# GitHub Personal Access Token
# Создать: https://github.com/settings/tokens → classic, scope: repo, workflow
GH_TOKEN=ghp_your_token_here

# GitHub username
GITHUB_USER=abcdef0101
