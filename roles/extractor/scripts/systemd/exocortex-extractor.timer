[Unit]
Description=Extractor inbox-check timer — {{NAMESPACE}} (every 3h)

[Timer]
OnCalendar=*-*-* 07:00:00
OnCalendar=*-*-* 10:00:00
OnCalendar=*-*-* 13:00:00
OnCalendar=*-*-* 16:00:00
OnCalendar=*-*-* 19:00:00
OnCalendar=*-*-* 22:00:00
Persistent=false
Unit=exocortex-extractor-{{NAMESPACE}}.service

[Install]
WantedBy=timers.target
