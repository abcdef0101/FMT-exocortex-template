[Unit]
Description=Exocortex Strategist week-review (Monday midnight)
After=network.target

[Service]
Type=oneshot
ExecStart={{WORKSPACE_DIR}}/FMT-exocortex-template/roles/strategist/scripts/strategist.sh week-review
StandardOutput=append:{{HOME_DIR}}/logs/strategist/systemd-weekreview.log
StandardError=append:{{HOME_DIR}}/logs/strategist/systemd-weekreview-error.log
Environment=HOME={{HOME_DIR}}
Environment=PATH=/usr/local/bin:/usr/bin:/bin:/usr/local/sbin
